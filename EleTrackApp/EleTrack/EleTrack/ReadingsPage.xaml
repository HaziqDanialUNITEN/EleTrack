<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EleTrack.ReadingsPage"
             BackgroundColor="#FAFAFA">

    <!-- Wrap the entire page in a Grid so we can overlay the full-screen photo viewer on top -->
    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="25">

                <!-- Header Section -->
                <VerticalStackLayout>
                    <Label Text="Meter Reading" FontSize="26" FontAttributes="Bold" TextColor="#1E293B" />
                    <Label Text="Log your electricity meter reading" FontSize="14" TextColor="#64748B" />
                </VerticalStackLayout>

                <!-- Add New Reading Card -->
                <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="20">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.02" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="15">

                        <HorizontalStackLayout Spacing="10" Margin="0,0,0,5">
                            <Image Source="lightning_green.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                            <Label Text="Add New Reading" FontSize="18" TextColor="#1E293B" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <Label Text="Current Credit (RM)" FontSize="13" TextColor="#1E293B" />
                            <Border BackgroundColor="#F1F5F9" StrokeThickness="0" StrokeShape="RoundRectangle 8" HeightRequest="45" Padding="15,0">
                                <Grid ColumnDefinitions="*, Auto">
                                    <Entry x:Name="CreditEntry" Grid.Column="0" Placeholder="Enter current credit value" PlaceholderColor="#94A3B8" TextColor="#1E293B" Keyboard="Numeric" BackgroundColor="Transparent" />
                                    
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- DATE & TIME SECTION -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Reading Date &amp; Time" FontSize="13" TextColor="#1E293B" />
                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                <Border BackgroundColor="#F1F5F9" StrokeThickness="0" StrokeShape="RoundRectangle 8" HeightRequest="45" Padding="10,0">
                                    <DatePicker x:Name="ReadingDatePicker" TextColor="#1E293B" BackgroundColor="Transparent" VerticalOptions="Center" />
                                </Border>
                                <Border Grid.Column="1" BackgroundColor="#F1F5F9" StrokeThickness="0" StrokeShape="RoundRectangle 8" HeightRequest="45" Padding="10,0">
                                    <TimePicker x:Name="ReadingTimePicker" TextColor="#1E293B" BackgroundColor="Transparent" VerticalOptions="Center" />
                                </Border>
                            </Grid>
                        </VerticalStackLayout>

                        <!-- PHOTO SECTION -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Meter Photo (Optional)" FontSize="13" TextColor="#1E293B" />
                            <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 8" HeightRequest="45">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnAttachPhotoTapped" />
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                                    <Image Source="camera_icon.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center"/>
                                    <Label x:Name="AttachPhotoLabel" Text="Attach Photo" TextColor="#1E293B" FontSize="14" VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>

                            <!-- Image Preview (Hidden by default) -->
                            <Border x:Name="PhotoPreviewContainer" IsVisible="False" BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 8" HeightRequest="150" Margin="0,5,0,0">
                                <Grid>
                                    <Image x:Name="PhotoPreviewImage" Aspect="AspectFill" />

                                    <!-- Remove Photo Button (Top Right) -->
                                    <Border BackgroundColor="#E11D48" StrokeThickness="0" StrokeShape="RoundRectangle 12" WidthRequest="24" HeightRequest="24" HorizontalOptions="End" VerticalOptions="Start" Margin="8">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnRemovePhotoTapped" />
                                        </Border.GestureRecognizers>
                                        <Label Text="✕" TextColor="White" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <Button Text="Submit Reading" BackgroundColor="#0AA67A" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="45" Margin="0,5,0,0" Clicked="OnSubmitReadingClicked"/>

                    </VerticalStackLayout>
                </Border>

                <!-- Reading History Section Title -->
                <Label Text="Reading History" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" Margin="0,5,0,-5"/>

                <!-- FILTER TABS -->
                <Border BackgroundColor="#F1F5F9" StrokeThickness="0" StrokeShape="RoundRectangle 25" Padding="4" HeightRequest="50" Margin="0,0,0,5">
                    <Grid ColumnDefinitions="*, *, *">
                        <!-- Daily Tab -->
                        <Border x:Name="DailyTabBorder" BackgroundColor="Transparent" StrokeThickness="0" StrokeShape="RoundRectangle 21" Margin="0,0,2,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnDailyFilterTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="DailyTabLabel" Text="Daily" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#64748B" FontSize="14" FontAttributes="None"/>
                        </Border>
                        <!-- Weekly Tab (Default) -->
                        <Border x:Name="WeeklyTabBorder" Grid.Column="1" BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 21" Margin="2,0,2,0">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.05" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnWeeklyFilterTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="WeeklyTabLabel" Text="Weekly" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#1E293B" FontSize="14" FontAttributes="Bold"/>
                        </Border>
                        <!-- All Tab -->
                        <Border x:Name="AllTabBorder" Grid.Column="2" BackgroundColor="Transparent" StrokeThickness="0" StrokeShape="RoundRectangle 21" Margin="2,0,0,0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAllFilterTapped" />
                            </Border.GestureRecognizers>
                            <Label x:Name="AllTabLabel" Text="All" HorizontalOptions="Center" VerticalOptions="Center" TextColor="#64748B" FontSize="14" FontAttributes="None"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- DATE NAVIGATOR -->
                <HorizontalStackLayout x:Name="DateNavigatorLayout" HorizontalOptions="Center" Spacing="20" Margin="0,0,0,10">
                    <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnPreviousDateTapped" />
                        </Border.GestureRecognizers>
                        <Image Source="back_arrow_icon.png" WidthRequest="16" HeightRequest="16" VerticalOptions="Center" HorizontalOptions="Center" />
                    </Border>

                    <Label x:Name="CurrentFilterDateLabel" Text="This Week" FontSize="15" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center" WidthRequest="150" HorizontalTextAlignment="Center"/>

                    <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 8" WidthRequest="36" HeightRequest="36">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNextDateTapped" />
                        </Border.GestureRecognizers>
                        <Image Source="chevron_right_icon.png" WidthRequest="16" HeightRequest="16" VerticalOptions="Center" HorizontalOptions="Center" />
                    </Border>
                </HorizontalStackLayout>

                <!-- Dynamic Reading History List -->
                <CollectionView x:Name="ReadingsCollection">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,30,0,30" Spacing="10">
                            <Image Source="clock_icon.png" WidthRequest="40" HeightRequest="40" Opacity="0.3" HorizontalOptions="Center"/>
                            <Label Text="No readings found for this period." TextColor="#94A3B8" FontSize="14" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="20" Margin="0,0,0,15">
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.02" />
                                </Border.Shadow>
                                <VerticalStackLayout Spacing="10">

                                    <Grid ColumnDefinitions="*, Auto">
                                        <HorizontalStackLayout Grid.Column="0" Spacing="12">
                                            <Border BackgroundColor="#D1FAE5" WidthRequest="32" HeightRequest="32" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                                <Image Source="lightning_green.png" WidthRequest="16" HeightRequest="16" VerticalOptions="Center" HorizontalOptions="Center"/>
                                            </Border>
                                            <Label Text="{Binding CreditValue, StringFormat='RM {0:F2}'}" FontSize="20" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>

                                        <Border Grid.Column="1" BackgroundColor="#D1FAE5" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="10,4" VerticalOptions="Center">
                                            <Label Text="Logged" TextColor="#059669" FontSize="12" FontAttributes="Bold"/>
                                        </Border>
                                    </Grid>

                                    <HorizontalStackLayout Spacing="6" Margin="0,5,0,0">
                                        <Image Source="clock_icon.png" WidthRequest="14" HeightRequest="14" VerticalOptions="Center"/>
                                        <Label Text="{Binding LocalDate, StringFormat='{0:MMMM d, yyyy, hh:mm tt}'}" FontSize="13" TextColor="#64748B" VerticalOptions="Center"/>
                                    </HorizontalStackLayout>

                                    <!-- Clickable square thumbnail of the attached photo -->
                                    <Border IsVisible="{Binding HasPhoto}" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 8" WidthRequest="60" HeightRequest="60" HorizontalOptions="Start" Margin="0,5,0,0">
                                        <Border.GestureRecognizers>
                                            <!-- CommandParameter passes the local photo path to our C# function -->
                                            <TapGestureRecognizer Tapped="OnViewPhotoTapped" CommandParameter="{Binding PhotoPath}" />
                                        </Border.GestureRecognizers>
                                        <Image Source="{Binding PhotoPath}" Aspect="AspectFill" />
                                    </Border>

                                    <Label Text="{Binding SubmittedBy, StringFormat='Submitted by {0}'}" FontSize="13" TextColor="#64748B" Margin="0,5,0,0" />

                                    <BoxView HeightRequest="1" Color="#F1F5F9" Margin="0,5" />

                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="Consumed:" FontSize="13" TextColor="#64748B" />
                                        <Label Text="{Binding Consumed, StringFormat='RM {0:F2}'}" FontSize="13" FontAttributes="Bold" TextColor="#E11D48" />
                                    </HorizontalStackLayout>

                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Full Screen Photo Viewer Overlay (Hidden by default) -->
        <Grid x:Name="FullScreenPhotoOverlay" IsVisible="False" BackgroundColor="#D9000000">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnCloseFullScreenPhotoTapped" />
            </Grid.GestureRecognizers>

            <Image x:Name="FullScreenImage" Aspect="AspectFit" Margin="20" />

            <!-- Close Button -->
            <Border BackgroundColor="#E11D48" StrokeThickness="0" StrokeShape="RoundRectangle 20" WidthRequest="40" HeightRequest="40" HorizontalOptions="End" VerticalOptions="Start" Margin="20,40,20,20">
                <Label Text="✕" TextColor="White" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center"/>
            </Border>
        </Grid>

    </Grid>
</ContentPage>