<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EleTrack.ReadingsPage"
             BackgroundColor="#FAFAFA">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="25">

            <!-- Header Section -->
            <VerticalStackLayout>
                <Label Text="Meter Reading" 
                       FontSize="26" 
                       FontAttributes="Bold" 
                       TextColor="#1E293B" />
                <Label Text="Log your electricity meter reading" 
                       FontSize="14" 
                       TextColor="#64748B" />
            </VerticalStackLayout>

            <!-- Add New Reading Card -->
            <Border BackgroundColor="White" 
                    Stroke="#E2E8F0"
                    StrokeThickness="1" 
                    StrokeShape="RoundRectangle 12"
                    Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.02" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="15">

                    <!-- Card Title -->
                    <HorizontalStackLayout Spacing="10" Margin="0,0,0,5">
                        <Image Source="lightning_green.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                        <Label Text="Add New Reading" FontSize="18" TextColor="#1E293B" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- Input: Current Credit -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Current Credit (RM)" FontSize="13" TextColor="#1E293B" />
                        <Border BackgroundColor="#F1F5F9" StrokeThickness="0" StrokeShape="RoundRectangle 8" HeightRequest="45" Padding="15,0">
                            <Grid ColumnDefinitions="*, Auto">
                                <Entry Grid.Column="0" 
                                       Placeholder="Enter current credit value" 
                                       PlaceholderColor="#94A3B8" 
                                       TextColor="#1E293B" 
                                       Keyboard="Numeric"
                                       BackgroundColor="Transparent" />
                                
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Input: Meter Photo -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Meter Photo (Optional)" FontSize="13" TextColor="#1E293B" />
                        <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 8" HeightRequest="45">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnAttachPhotoTapped" />
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10">
                                <Image Source="camera_icon.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center"/>
                                <Label Text="Attach Photo" TextColor="#1E293B" FontSize="14" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Submit Button -->
                    <Button Text="Submit Reading" 
                            BackgroundColor="#0AA67A" 
                            TextColor="White" 
                            FontAttributes="Bold" 
                            CornerRadius="8" 
                            HeightRequest="45" 
                            Margin="0,5,0,0"
                            Clicked="OnSubmitReadingClicked"/>

                </VerticalStackLayout>
            </Border>

            <!-- Reading History Section Title -->
            <Label Text="Reading History" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" Margin="0,5,0,-10"/>

            <!-- History Item 1 (Latest) -->
            <Border BackgroundColor="White" 
                    Stroke="#E2E8F0"
                    StrokeThickness="1" 
                    StrokeShape="RoundRectangle 12"
                    Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.02" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">

                    <Grid ColumnDefinitions="*, Auto">
                        <HorizontalStackLayout Grid.Column="0" Spacing="12">
                            <Border BackgroundColor="#D1FAE5" WidthRequest="32" HeightRequest="32" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                                <Image Source="lightning_green.png" WidthRequest="16" HeightRequest="16" VerticalOptions="Center" HorizontalOptions="Center"/>
                            </Border>
                            <Label Text="RM 45.80" FontSize="20" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center"/>
                        </HorizontalStackLayout>

                        <!-- Latest Badge -->
                        <Border Grid.Column="1" BackgroundColor="#D1FAE5" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="10,4" VerticalOptions="Center">
                            <Label Text="Latest" TextColor="#059669" FontSize="12" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <HorizontalStackLayout Spacing="6" Margin="0,5,0,0">
                        <Image Source="clock_icon.png" WidthRequest="14" HeightRequest="14" VerticalOptions="Center"/>
                        <Label Text="March 5, 2026 at 09:15 AM" FontSize="13" TextColor="#64748B" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Label Text="Submitted by Ahmad" FontSize="13" TextColor="#64748B" />

                    <BoxView HeightRequest="1" Color="#F1F5F9" Margin="0,5" />

                    <HorizontalStackLayout Spacing="4">
                        <Label Text="Consumed:" FontSize="13" TextColor="#64748B" />
                        <Label Text="RM 22.70" FontSize="13" FontAttributes="Bold" TextColor="#E11D48" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- History Item 2 -->
            <Border BackgroundColor="White" 
                    Stroke="#E2E8F0"
                    StrokeThickness="1" 
                    StrokeShape="RoundRectangle 12"
                    Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.02" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">

                    <HorizontalStackLayout Spacing="12">
                        <Border BackgroundColor="#D1FAE5" WidthRequest="32" HeightRequest="32" StrokeThickness="0" StrokeShape="RoundRectangle 16">
                            <Image Source="lightning_green.png" WidthRequest="16" HeightRequest="16" VerticalOptions="Center" HorizontalOptions="Center"/>
                        </Border>
                        <Label Text="RM 68.50" FontSize="20" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="6" Margin="0,5,0,0">
                        <Image Source="clock_icon.png" WidthRequest="14" HeightRequest="14" VerticalOptions="Center"/>
                        <Label Text="March 1, 2026 at 10:30 AM" FontSize="13" TextColor="#64748B" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Label Text="Submitted by Sarah" FontSize="13" TextColor="#64748B" />

                    <BoxView HeightRequest="1" Color="#F1F5F9" Margin="0,5" />

                    <HorizontalStackLayout Spacing="4">
                        <Label Text="Consumed:" FontSize="13" TextColor="#64748B" />
                        <Label Text="RM 31.50" FontSize="13" FontAttributes="Bold" TextColor="#E11D48" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>