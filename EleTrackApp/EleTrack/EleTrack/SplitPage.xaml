<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EleTrack.SplitPage"
             BackgroundColor="#FAFAFA">

    <ScrollView>
        <!-- Added BackgroundColor here so the screenshot captures a solid background -->
        <VerticalStackLayout x:Name="MainContent" Padding="20" Spacing="20" BackgroundColor="#FAFAFA">

            <VerticalStackLayout>
                <Label Text="Bill Split" FontSize="26" FontAttributes="Bold" TextColor="#1E293B" />
                <Label Text="Fair division of electricity costs" FontSize="14" TextColor="#64748B" />
            </VerticalStackLayout>

            <!-- Total Bill Card -->
            <Border BackgroundColor="#4F46E5" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="#4F46E5" Offset="0,4" Radius="10" Opacity="0.3" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="15">
                    <HorizontalStackLayout Spacing="10">
                        <Image Source="dollar_icon_white.png" WidthRequest="18" HeightRequest="18" VerticalOptions="Center"/>
                        <Label Text="Total Bill This Period" FontSize="15" TextColor="White" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Label x:Name="TotalBillLabel" Text="RM 0.00" FontSize="48" FontAttributes="Bold" TextColor="White" />

                    <HorizontalStackLayout Spacing="8">
                        <Image Source="people_icon_white.png" WidthRequest="16" HeightRequest="16" VerticalOptions="Center"/>
                        <Label x:Name="SplitAmongLabel" Text="Split among 0 housemates" FontSize="13" TextColor="#E0E7FF" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Payment Progress -->
            <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.02" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">
                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Payment Progress" FontSize="13" TextColor="#334155" />
                        <Label x:Name="PaymentProgressTextLabel" Grid.Column="1" Text="RM 0.00 / RM 0.00" FontSize="13" FontAttributes="Bold" TextColor="#059669" />
                    </Grid>

                    <ProgressBar x:Name="PaymentProgressBar" Progress="0" ProgressColor="#0F172A" HeightRequest="8" />

                    <Label x:Name="PaidCountLabel" Text="0 of 0 paid" FontSize="12" TextColor="#64748B" />
                </VerticalStackLayout>
            </Border>

            <Label Text="Individual Shares" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" Margin="0,10,0,0"/>

            <!-- Dynamic Housemates Split List (Swapped to BindableLayout so full screenshot works properly) -->
            <VerticalStackLayout x:Name="SplitCollection">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <!-- Main Card Border with DataTriggers -->
                        <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="20" Margin="0,0,0,15">
                            <Border.Triggers>
                                <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Paid">
                                    <Setter Property="BackgroundColor" Value="#ECFDF5" />
                                    <Setter Property="Stroke" Value="#A7F3D0" />
                                </DataTrigger>
                            </Border.Triggers>

                            <VerticalStackLayout Spacing="8">
                                <Grid ColumnDefinitions="Auto, Auto, *">
                                    <Label Grid.Column="0" Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center" Margin="0,0,10,0"/>

                                    <Border Grid.Column="1" BackgroundColor="#FFEDD5" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="8,2" VerticalOptions="Center">
                                        <Label Text="{Binding Modifier, StringFormat='{0}× modifier'}" TextColor="#C2410C" FontSize="11" FontAttributes="Bold"/>
                                    </Border>

                                    <!-- Status Badge with DataTriggers -->
                                    <Border Grid.Column="2" BackgroundColor="#E2E8F0" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="10,4" HorizontalOptions="End" VerticalOptions="Center">
                                        <Border.Triggers>
                                            <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Paid">
                                                <Setter Property="BackgroundColor" Value="#059669" />
                                            </DataTrigger>
                                        </Border.Triggers>
                                        <Label Text="{Binding Status}" TextColor="#475569" FontSize="12" FontAttributes="Bold">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Paid">
                                                    <Setter Property="Text" Value="✓ Paid" />
                                                    <Setter Property="TextColor" Value="White" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Border>
                                </Grid>

                                <Label Text="Base share adjusted by usage pattern" FontSize="13" TextColor="#64748B" LineBreakMode="WordWrap"/>
                                <Label Text="{Binding AmountDue, StringFormat='RM {0:F2}'}" FontSize="22" FontAttributes="Bold" TextColor="#1E293B" Margin="0,5,0,0"/>
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <!-- About Modifiers Note -->
            <Border BackgroundColor="#FFFBEB" Stroke="#FEF08A" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="15" Margin="0,10,0,0">
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout Spacing="8">
                        <Image Source="info_icon_blue.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                        <Label Text="About Modifiers" FontSize="16" FontAttributes="Bold" TextColor="#9A3412" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Text="Usage modifiers fairly adjust bills for housemates with higher electricity needs. Set modifiers in Settings." FontSize="13" TextColor="#B45309" LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Border>

            <!-- Share Summary Button -->
            <Button x:Name="ShareButton" Text="Share Bill Summary" BackgroundColor="#4F46E5" TextColor="White" FontAttributes="Bold" CornerRadius="8" HeightRequest="50" Margin="0,10,0,20" ImageSource="share_icon_white.png" ContentLayout="Left, 10" Clicked="OnShareBillSummaryClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>