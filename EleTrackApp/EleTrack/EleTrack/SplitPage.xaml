<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EleTrack.SplitPage"
             BackgroundColor="#FAFAFA">

    <ScrollView>
        <VerticalStackLayout x:Name="MainContent" Padding="20" Spacing="20">

            <!-- Header Section -->
            <VerticalStackLayout>
                <Label Text="Bill Split" 
                       FontSize="26" 
                       FontAttributes="Bold" 
                       TextColor="#1E293B" />
                <Label Text="Fair division of electricity costs" 
                       FontSize="14" 
                       TextColor="#64748B" />
            </VerticalStackLayout>

            <!-- Total Bill Card -->
            <Border BackgroundColor="#4F46E5" 
                    StrokeThickness="0" 
                    StrokeShape="RoundRectangle 12"
                    Padding="20">
                <Border.Shadow>
                    <Shadow Brush="#4F46E5" Offset="0,4" Radius="10" Opacity="0.3" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="15">

                    <HorizontalStackLayout Spacing="10">
                        
                        <Label Text="Total Bill This Period" FontSize="15" TextColor="White" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <Label Text="RM 54.20" 
                           FontSize="48" 
                           FontAttributes="Bold" 
                           TextColor="White" />

                    <HorizontalStackLayout Spacing="8">
                        
                        <Label Text="Split among 4 housemates" FontSize="13" TextColor="#E0E7FF" VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

            <!-- Payment Progress -->
            <Border BackgroundColor="White" 
                    Stroke="#E2E8F0"
                    StrokeThickness="1" 
                    StrokeShape="RoundRectangle 12"
                    Padding="20">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.02" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="10">

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Payment Progress" FontSize="13" TextColor="#334155" />
                        <Label Grid.Column="1" Text="RM 27.10 / RM 54.20" FontSize="13" FontAttributes="Bold" TextColor="#059669" />
                    </Grid>

                    <!-- Custom Progress Bar -->
                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 4" HeightRequest="8" BackgroundColor="#CBD5E1">
                        <Grid ColumnDefinitions="5*, 5*">
                            <!-- Black portion represents paid -->
                            <BoxView Grid.Column="0" Color="#0F172A" />
                        </Grid>
                    </Border>

                    <Label Text="2 of 4 paid" FontSize="12" TextColor="#64748B" />
                </VerticalStackLayout>
            </Border>

            <!-- Individual Shares Title -->
            <Label Text="Individual Shares" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" Margin="0,10,0,0"/>

            <!-- Ahmad's Card (Paid) -->
            <Border BackgroundColor="#ECFDF5" 
                    Stroke="#A7F3D0"
                    StrokeThickness="1" 
                    StrokeShape="RoundRectangle 12"
                    Padding="20">
                <VerticalStackLayout Spacing="8">

                    <Grid ColumnDefinitions="*, Auto">
                        <Label Grid.Column="0" Text="Ahmad" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center"/>

                        <!-- Paid Badge -->
                        <Border Grid.Column="1" BackgroundColor="#059669" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="10,4" VerticalOptions="Center">
                            <Label Text="✓ Paid" TextColor="White" FontSize="12" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <Label Text="Base share adjusted by usage pattern" FontSize="13" TextColor="#64748B" />
                    <Label Text="RM 13.55" FontSize="22" FontAttributes="Bold" TextColor="#1E293B" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Border>

            <!-- Sarah's Card (Pending) -->
            <Border BackgroundColor="White" 
                    Stroke="#E2E8F0"
                    StrokeThickness="1" 
                    StrokeShape="RoundRectangle 12"
                    Padding="20">
                <VerticalStackLayout Spacing="8">

                    <Grid ColumnDefinitions="Auto, Auto, *">
                        <Label Grid.Column="0" Text="Sarah" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center" Margin="0,0,10,0"/>

                        <!-- Modifier Badge -->
                        <Border Grid.Column="1" BackgroundColor="#FFEDD5" StrokeThickness="0" StrokeShape="RoundRectangle 10" Padding="8,2" VerticalOptions="Center">
                            <Label Text="0.8× modifier" TextColor="#C2410C" FontSize="11" FontAttributes="Bold"/>
                        </Border>

                        <!-- Pending Badge -->
                        <Border Grid.Column="2" BackgroundColor="#E2E8F0" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="10,4" HorizontalOptions="End" VerticalOptions="Center">
                            <Label Text="Pending" TextColor="#475569" FontSize="12" FontAttributes="Bold"/>
                        </Border>
                    </Grid>

                    <Label Text="Adjusted for higher usage • Base share adjusted by usage pattern" FontSize="13" TextColor="#64748B" LineBreakMode="WordWrap"/>
                    <Label Text="RM 10.84" FontSize="22" FontAttributes="Bold" TextColor="#1E293B" Margin="0,5,0,0"/>
                </VerticalStackLayout>
            </Border>

            <!-- About Modifiers Info Card -->
            <Border BackgroundColor="#FFFBEB" 
                    Stroke="#FEF08A"
                    StrokeThickness="1" 
                    StrokeShape="RoundRectangle 12"
                    Padding="15"
                    Margin="0,10,0,0">
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout Spacing="8">
                        <!-- Standard info icon, use yours if available -->
                        <Image Source="info_icon_blue.png" WidthRequest="20" HeightRequest="20" VerticalOptions="Center"/>
                        <Label Text="About Modifiers" FontSize="16" FontAttributes="Bold" TextColor="#9A3412" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Text="Usage modifiers fairly adjust bills for housemates with higher electricity needs (e.g., gaming PCs, personal fridges). Set modifiers in Settings." 
                           FontSize="13" 
                           TextColor="#B45309" 
                           LineBreakMode="WordWrap"/>
                </VerticalStackLayout>
            </Border>

            <!-- Share Button -->
            <Button Text="Share Bill Summary" 
                    BackgroundColor="#4F46E5" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    CornerRadius="8" 
                    HeightRequest="50" 
                    Margin="0,10,0,20"
                    ImageSource="share_icon_white.png"
                    ContentLayout="Left, 10"
                    Clicked="OnShareBillSummaryClicked"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>